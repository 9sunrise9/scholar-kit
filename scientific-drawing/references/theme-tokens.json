{
  "_comment": "统一主题配置源（Single Source of Truth）— TikZ 与 Python 均从此文件读取配色与视觉样式。更新后运行 scripts/sync_theme_tokens.py 可同步到 tikz-theme.tex。",

  "default_theme": "schematic_general",

  "shared": {
    "typography": {
      "font_family_sans":   "Source Han Sans CN",
      "font_family_sans_fallback": ["Noto Sans CJK SC", "Microsoft YaHei", "PingFang SC", "SimHei", "Arial Unicode MS", "DejaVu Sans"],
      "font_family_serif":  "Source Han Serif CN",
      "font_size_pt":       13,
      "title_size_pt":      20,
      "label_size_pt":      16,
      "tick_size_pt":       13,
      "legend_size_pt":     13,
      "tikz_font_cmd":      "\\normalsize"
    },
    "strokes": {
      "axis_width":         2.0,
      "line_width_main":    2.4,
      "line_width_minor":   1.6,
      "line_width_thin":    1.0,
      "arrow_width":        1.8,
      "node_border_width":  1.6
    },
    "line_styles": {
      "solid":              "solid",
      "dashed":             "dashed",
      "dotted":             "dotted",
      "dash_dot":           "dashdotted",
      "loosely_dashed":     "loosely dashed",
      "densely_dashed":     "densely dashed"
    },
    "markers": {
      "circle":             "o",
      "square":             "s",
      "triangle":           "^",
      "diamond":            "D",
      "cross":              "x",
      "star":               "*",
      "marker_size":        6
    },
    "layout": {
      "grid_alpha":         0.12,
      "legend_frame_alpha": 0.85,
      "figure_dpi":         150,
      "border_standalone":  "15pt 10pt 10pt 10pt",
      "tight_layout":       true,
      "spine_width":        2.0
    }
  },

  "themes": {
    "schematic_general": {
      "type":    "schematic",
      "goal":    "clear logic, low saturation, high contrast",
      "colors": {
        "background":     "#FFFFFF",
        "text":           "#000000",
        "secondary_text": "#4D4D4D",
        "outline":        "#4D4D4D",
        "fill_neutral":   "#D9D9D9",
        "primary":        "#0072B2",
        "accent_1":       "#E69F00",
        "accent_2":       "#009E73",
        "accent_3":       "#CC79A7",
        "warning":        "#D55E00",
        "grid":           "#E5E5E5"
      },
      "usage": {
        "main_structure":        ["#000000", "#4D4D4D", "#D9D9D9"],
        "key_path":              ["#0072B2"],
        "highlight":             ["#E69F00"],
        "supporting_module":     ["#009E73", "#CC79A7"],
        "warning_or_inhibition": ["#D55E00"]
      },
      "rules": [
        "use at most 5 visible colors in one schematic",
        "prefer arrows, positions, and labels over color-only meaning",
        "ensure grayscale readability"
      ]
    },

    "biomedical_mechanism": {
      "type":    "schematic",
      "goal":    "mechanistic clarity with scientific restraint",
      "colors": {
        "background":      "#FFFFFF",
        "text":            "#000000",
        "cell_or_tissue":  "#D9D9D9",
        "pathway_active":  "#0072B2",
        "pathway_support": "#009E73",
        "treatment":       "#E69F00",
        "inhibition":      "#D55E00",
        "marker":          "#CC79A7",
        "control":         "#808080",
        "grid":            "#E5E5E5"
      },
      "usage": {
        "control":    "#808080",
        "activation": "#0072B2",
        "suppression":"#D55E00",
        "treatment":  "#E69F00",
        "biomarker":  "#CC79A7"
      },
      "rules": [
        "avoid neon greens and intense reds",
        "do not use more than one warning color",
        "keep all labels in black or dark gray"
      ]
    },

    "engineering_schematic": {
      "type":    "schematic",
      "goal":    "process clarity and structural hierarchy",
      "colors": {
        "background":    "#FFFFFF",
        "text":          "#000000",
        "structure":     "#4D4D4D",
        "material_a":    "#0072B2",
        "material_b":    "#E69F00",
        "material_c":    "#009E73",
        "process_flow":  "#56B4E9",
        "failure_alert": "#D55E00",
        "grid":          "#E5E5E5"
      },
      "usage": {
        "base":      ["#000000", "#4D4D4D", "#D9D9D9"],
        "materials": ["#0072B2", "#E69F00", "#009E73"],
        "process":   ["#56B4E9"],
        "alert":     ["#D55E00"]
      },
      "rules": [
        "prefer color to distinguish material classes, not decorative regions",
        "ensure all filled shapes remain clear in grayscale",
        "use line style and stroke width to reinforce hierarchy"
      ]
    },

    "line_chart_general": {
      "type":    "data",
      "goal":    "series separation with print-safe contrast",
      "colors": {
        "background": "#FFFFFF",
        "axis":       "#000000",
        "grid":       "#E5E5E5",
        "series_1":   "#0072B2",
        "series_2":   "#E69F00",
        "series_3":   "#009E73",
        "series_4":   "#CC79A7",
        "series_5":   "#D55E00",
        "series_6":   "#56B4E9"
      },
      "usage": {
        "best_for":   ["2_series", "3_series", "4_series", "5_series"],
        "line_width": "medium_to_bold",
        "marker":     "recommended",
        "legend":     "simple_and_short"
      },
      "rules": [
        "combine color with line style and marker",
        "keep maximum clarity in grayscale",
        "do not use rainbow colormap"
      ]
    },

    "continuous_data": {
      "type":    "data",
      "goal":    "single-hue monotonic progression",
      "colors": {
        "low":      "#EAF3FF",
        "low_mid":  "#CFE3FF",
        "mid":      "#9CC7FF",
        "high_mid": "#5BA5FF",
        "high":     "#2E7DFF",
        "max":      "#005BBB",
        "background": "#FFFFFF",
        "axis":     "#000000",
        "grid":     "#E5E5E5"
      },
      "usage": {
        "best_for":       ["intensity_map", "trend_strength", "continuous_score"],
        "preferred_hue":  "blue",
        "alternative_hue":"gray"
      },
      "rules": [
        "use sequential palettes only",
        "avoid categorical or rainbow schemes",
        "preserve monotonic perception"
      ]
    },

    "diverging_data": {
      "type":    "data",
      "goal":    "positive-negative deviation around neutral center",
      "colors": {
        "negative_strong": "#2166AC",
        "negative_mid":    "#67A9CF",
        "negative_soft":   "#D1E5F0",
        "center":          "#F7F7F7",
        "positive_soft":   "#FDDBC7",
        "positive_mid":    "#EF8A62",
        "positive_strong": "#B2182B",
        "background":      "#FFFFFF",
        "axis":            "#000000",
        "grid":            "#E5E5E5"
      },
      "usage": {
        "best_for":     ["delta", "difference", "correlation_shift", "deviation"],
        "center_value": "neutral_gray"
      },
      "rules": [
        "place neutral value at the center",
        "ensure both sides have balanced perceptual contrast",
        "avoid using vivid green-red diverging palettes"
      ]
    },

    "categorical_comparison": {
      "type":    "data",
      "goal":    "distinct categorical separation",
      "colors": {
        "cat_1":      "#0072B2",
        "cat_2":      "#E69F00",
        "cat_3":      "#009E73",
        "cat_4":      "#CC79A7",
        "cat_5":      "#D55E00",
        "cat_6":      "#56B4E9",
        "background": "#FFFFFF",
        "axis":       "#000000",
        "grid":       "#E5E5E5"
      },
      "usage": {
        "best_for": ["bar_chart", "grouped_scatter", "multi_line", "boxplot_groups"]
      },
      "rules": [
        "use the same category color across all figures in the paper",
        "if more than 6 categories are needed, add line style, fill pattern, or marker",
        "do not rely on color alone"
      ]
    }
  }
}
